-- Copy instance completely
local function CopyInstance(instance, recursive)
    local data = {
        Class = instance.ClassName,
        Name = instance.Name,
        Properties = {},
        Children = {},
    }
    
    -- Get all properties
    if MapSystem.Settings.IncludeProperties then
        local props = {}
        for _, prop in ipairs(instance:GetProperties()) do
            local success, value = pcall(function()
                return instance[prop]
            end)
            if success and value ~= nil then
                -- Handle special types
                if type(value) == "Vector3" then
                    props[prop] = {X = value.X, Y = value.Y, Z = value.Z}
                elseif type(value) == "CFrame" then
                    local x, y, z, r00, r01, r02, r10, r11, r12, r20, r21, r22 = value:GetComponents()
                    props[prop] = {
                        X = x, Y = y, Z = z,
                        R00 = r00, R01 = r01, R02 = r02,
                        R10 = r10, R11 = r11, R12 = r12,
                        R20 = r20, R21 = r21, R22 = r22
                    }
                elseif type(value) == "Color3" then
                    props[prop] = {R = value.R, G = value.G, B = value.B}
                elseif type(value) == "BrickColor" then
                    props[prop] = value.Number
                elseif type(value) == "UDim2" then
                    props[prop] = {X = value.X, Y = value.Y, Width = value.Width.Offset, Height = value.Height.Offset}
                elseif type(value) ~= "table" and type(value) ~= "userdata" and type(value) ~= "function" then
                    props[prop] = value
                end
            end
        end
        data.Properties = props
    end
    
    -- Copy children
    if recursive then
        for _, child in ipairs(instance:GetChildren()) do
            table.insert(data.Children, CopyInstance(child, true))
        end
    end
    
    return data
end

-- Create instance from data
local function CreateInstance(data, parent)
    local instance = Instance.new(data.Class)
    instance.Name = data.Name
    
    -- Apply properties
    for prop, value in pairs(data.Properties) do
        pcall(function()
            -- Handle special types
            if type(value) == "table" then
                if value.X and value.Y and value.Z then
                    instance[prop] = Vector3.new(value.X, value.Y, value.Z)
                elseif value.R and value.G and value.B then
                    instance[prop] = Color3.new(value.R, value.G, value.B)
                elseif value.R00 then
                    instance[prop] = CFrame.new(
                        value.X, value.Y, value.Z,
                        value.R00, value.R01, value.R02,
                        value.R10, value.R11, value.R12,
                        value.R20, value.R21, value.R22
                    )
                elseif value.X and value.Y and value.Width and value.Height then
                    instance[prop] = UDim2.new(value.X, value.Width, value.Y, value.Height)
                else
                    instance[prop] = value
                end
            else
                instance[prop] = value
            end
        end)
    end
    
    -- Create children
    for _, childData in ipairs(data.Children) do
        CreateInstance(childData, instance)
    end
    
    instance.Parent = parent
    return instance
end

-- Highlight part
local function HighlightPart(part, color, duration)
    if not part or not part.Parent then return end
    
    local highlight = Instance.new("Highlight")
    highlight.Adornee = part
    highlight.FillColor = color or Colors.Primary
    highlight.FillTransparency = 0.5
    highlight.OutlineColor = Colors.Text
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Parent = part
    
    if duration then
        task.delay(duration, function()
            if highlight then highlight:Destroy() end
        end)
    end
    
    return highlight
end

-- Select part
local function SelectPart(part)
    if not part then return end
    
    -- Clear previous highlight
    if MapSystem.Selected and MapSystem.Selected.Highlight then
        MapSystem.Selected.Highlight:Destroy()
    end
    
    MapSystem.Selected = {
        Part = part,
        Highlight = HighlightPart(part, Colors.Accent)
    }
    
    Notify("Selected", "Selected: " .. part.Name, 2, "success")
end

-- Copy selected
local function CopySelected()
    if not MapSystem.Selected then
        Notify("Error", "No part selected!", 2, "error")
        return
    end
    
    MapSystem.Clipboard = {
        CopyInstance(MapSystem.Selected.Part, MapSystem.Settings.IncludeChildren)
    }
    
    MapSystem.Stats.TotalCopied = MapSystem.Stats.TotalCopied + 1
    
    -- Add to history
    table.insert(MapSystem.History, {
        type = "copy",
        data = MapSystem.Clipboard,
        time = os.time()
    })
    MapSystem.HistoryIndex = #MapSystem.History
    
    Notify("Copied", "Instance copied to clipboard", 2, "success")
end

-- Paste at position
local function PasteAtPosition(position)
    if #MapSystem.Clipboard == 0 then
        Notify("Error", "Clipboard is empty!", 2, "error")
        return
    end
    
    if not position then
        position = Mouse.Hit.p + MapSystem.Settings.PasteOffset
    end
    
    -- Snap to grid
    if MapSystem.Settings.SnapToGrid then
        local grid = MapSystem.Settings.GridSize
        position = Vector3.new(
            math.round(position.X / grid) * grid,
            math.round(position.Y / grid) * grid,
            math.round(position.Z / grid) * grid
        )
    end
    
    local pastedGroup = Instance.new("Model")
    pastedGroup.Name = "Pasted_" .. os.date("%H%M%S")
    pastedGroup.Parent = Workspace
    
    for _, data in ipairs(MapSystem.Clipboard) do
        local instance = CreateInstance(data, pastedGroup)
        
        -- Adjust position if it's a BasePart
        if instance:IsA("BasePart") then
            instance.CFrame = instance.CFrame + (position - instance.Position)
        end
        
        -- Highlight briefly
        if instance:IsA("BasePart") then
            HighlightPart(instance, Colors.Success, 1)
        end
    end
    
    MapSystem.Stats.TotalPasted = MapSystem.Stats.TotalPasted + 1
    Notify("Pasted", "Instance pasted successfully", 2, "success")
    
    return pastedGroup
end

