UserInputService.InputBegan:Connect(function(input, processed)
    if processed then return end
    
    -- F2 for selection mode
    if input.KeyCode == Enum.KeyCode.F2 then
        MapSystem.UI.SelectionMode = true
        Notify("Selection Mode", "Click any part to select", 2, "info")
    end
    
    -- Ctrl combinations
    if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then
        if input.KeyCode == Enum.KeyCode.C then
            if MapSystem.Selected and MapSystem.Selected.Part then
                if MapSystem.Settings.IncludeChildren then
                    local parts = CollectParts(MapSystem.Selected.Part, true)
                    CopyParts(parts)
                else
                    CopyParts({MapSystem.Selected.Part})
                end
            end
        elseif input.KeyCode == Enum.KeyCode.V then
            PasteParts()
        elseif input.KeyCode == Enum.KeyCode.S then
            SaveMap()
        elseif input.KeyCode == Enum.KeyCode.Z then
            Undo()
        elseif input.KeyCode == Enum.KeyCode.Y then
            Redo()
        end
    end
    
    -- Delete key to clear selection
    if input.KeyCode == Enum.KeyCode.Delete then
        if MapSystem.Selected and MapSystem.Selected.Highlight then
            MapSystem.Selected.Highlight:Destroy()
        end
        MapSystem.Selected = nil
        Notify("Selection Cleared", "No part selected", 1, "info")
    end
end)

-- Mouse click for selection
Mouse.Button1Down:Connect(function()
    if MapSystem.UI.SelectionMode and Mouse.Target then
        SelectPart(Mouse.Target)
        MapSystem.UI.SelectionMode = false
    elseif MapSystem.Settings.AutoSelect and Mouse.Target then
        SelectPart(Mouse.Target)
    end
end)

-- Auto-save timer
if MapSystem.Settings.AutoSave then
    task.spawn(function()
        while true do
            task.wait(MapSystem.Settings.AutoSaveInterval)
            if #MapSystem.Clipboard > 0 then
                SaveMap("autosave_" .. os.date("%Y%m%d_%H%M%S") .. ".json")
            end
        end
    end)
end

-- Update grid position
RunService.Heartbeat:Connect(function()
    if MapSystem.UI.ShowGrid and Camera then
        CreateGrid(Camera.CFrame.Position, 50, MapSystem.Settings.GridSize)
    end
end)

