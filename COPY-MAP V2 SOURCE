-- Generate source code
local function GenerateSource()
    if #MapSystem.Clipboard == 0 then
        Notify("Error", "Nothing to export!", 2, "error")
        return
    end
    
    local function generateInstanceCode(data, indent)
        indent = indent or ""
        local code = indent .. "local instance = Instance.new(\"" .. data.Class .. "\")\n"
        code = code .. indent .. "instance.Name = \"" .. data.Name .. "\"\n"
        
        for prop, value in pairs(data.Properties) do
            if type(value) == "string" then
                code = code .. indent .. "instance." .. prop .. " = \"" .. value .. "\"\n"
            elseif type(value) == "number" then
                code = code .. indent .. "instance." .. prop .. " = " .. value .. "\n"
            elseif type(value) == "boolean" then
                code = code .. indent .. "instance." .. prop .. " = " .. tostring(value) .. "\n"
            elseif type(value) == "table" then
                if value.X and value.Y and value.Z then
                    code = code .. indent .. "instance." .. prop .. " = Vector3.new(" .. value.X .. ", " .. value.Y .. ", " .. value.Z .. ")\n"
                elseif value.R and value.G and value.B then
                    code = code .. indent .. "instance." .. prop .. " = Color3.new(" .. value.R .. ", " .. value.G .. ", " .. value.B .. ")\n"
                end
            end
        end
        
        for _, child in ipairs(data.Children) do
            code = code .. generateInstanceCode(child, indent .. "    ")
        end
        
        return code
    end
    
    local source = "-- Generated by FIQQZR7 Map Copy v6.0\n"
    source = source .. "-- Date: " .. os.date("%Y-%m-%d %H:%M:%S") .. "\n"
    source = source .. "-- Author: " .. Player.Name .. "\n\n"
    
    source = source .. "local Workspace = game:GetService(\"Workspace\")\n"
    source = source .. "local Group = Instance.new(\"Model\")\n"
    source = source .. "Group.Name = \"Pasted_" .. os.date("%H%M%S") .. "\"\n"
    source = source .. "Group.Parent = Workspace\n\n"
    
    for i, data in ipairs(MapSystem.Clipboard) do
        source = source .. "-- Instance " .. i .. "\n"
        source = source .. generateInstanceCode(data, "")
        source = source .. "instance.Parent = Group\n\n"
    end
    
    return source
end

