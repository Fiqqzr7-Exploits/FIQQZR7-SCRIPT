-- Highlight Part
local function HighlightPart(part, color, duration)
    if not part or not part.Parent then return end
    
    local highlight = Instance.new("Highlight")
    highlight.Adornee = part
    highlight.FillColor = color or Color3.fromRGB(0, 180, 216)
    highlight.OutlineColor = Color3.fromRGB(255, 255, 255)
    highlight.FillTransparency = 0.5
    highlight.DepthMode = Enum.HighlightDepthMode.AlwaysOnTop
    highlight.Parent = part
    
    if duration then
        task.delay(duration, function()
            if highlight then highlight:Destroy() end
        end)
    end
    
    return highlight
end

-- Select Part
local function SelectPart(part)
    if not part or not part:IsA("BasePart") then return end
    
    -- Clear previous selection highlight
    if MapSystem.Selected and MapSystem.Selected.Highlight then
        MapSystem.Selected.Highlight:Destroy()
    end
    
    MapSystem.Selected = {
        Part = part,
        Highlight = MapSystem.Settings.HighlightSelected and HighlightPart(part, Color3.fromRGB(255, 0, 0)) or nil
    }
    
    Notify("Selected", part.Name, 1, "success")
end

-- Collect Parts from Model
local function CollectParts(root, recursive)
    local parts = {}
    
    local function scan(instance)
        for _, child in ipairs(instance:GetChildren()) do
            if child:IsA("BasePart") then
                table.insert(parts, child)
            end
            if recursive then
                scan(child)
            end
        end
    end
    
    scan(root)
    return parts
end

-- Copy Parts
local function CopyParts(parts)
    if #parts == 0 then
        Notify("Error", "No parts to copy!", 2, "error")
        return
    end
    
    MapSystem.Clipboard = {}
    
    for _, part in ipairs(parts) do
        local data = {
            Name = part.Name,
            Class = part.ClassName,
            Position = part.Position,
            Size = part.Size,
            CFrame = part.CFrame,
            Color = part.BrickColor,
            Material = part.Material,
            Color3 = part.Color,
            Transparency = part.Transparency,
            Reflectance = part.Reflectance,
            Anchored = part.Anchored,
            CanCollide = part.CanCollide,
            CanTouch = part.CanTouch,
            Locked = part.Locked,
            Massless = part.Massless,
            CustomPhysicalProperties = part.CustomPhysicalProperties,
            CollisionGroup = part.CollisionGroup,
            BrickColor = part.BrickColor,
            Orientation = part.Orientation,
            Rotation = part.Rotation,
            Velocity = part.Velocity,
            RotVelocity = part.RotVelocity,
            AssemblyMass = part.AssemblyMass,
            AssemblyLinearVelocity = part.AssemblyLinearVelocity,
            AssemblyAngularVelocity = part.AssemblyAngularVelocity,
            Parent = part.Parent,
            -- Special properties
            Shape = part.Shape, -- For wedges/cylinders
            TopSurface = part.TopSurface,
            BottomSurface = part.BottomSurface,
            FrontSurface = part.FrontSurface,
            BackSurface = part.BackSurface,
            LeftSurface = part.LeftSurface,
            RightSurface = part.RightSurface,
        }
        
        -- Handle decals and textures
        data.Decals = {}
        for _, child in ipairs(part:GetChildren()) do
            if child:IsA("Decal") or child:IsA("Texture") then
                table.insert(data.Decals, {
                    Class = child.ClassName,
                    Name = child.Name,
                    Texture = child.Texture,
                    Color3 = child.Color3,
                    Transparency = child.Transparency,
                    Face = child.Face,
                })
            end
        end
        
        table.insert(MapSystem.Clipboard, data)
    end
    
    MapSystem.Stats.TotalCopied = MapSystem.Stats.TotalCopied + #parts
    Notify("Copied", string.format("%d parts copied to clipboard", #parts), 2, "success")
    
    -- Add to history
    if #MapSystem.History >= MapSystem.Settings.MaxHistory then
        table.remove(MapSystem.History, 1)
    end
    table.insert(MapSystem.History, {
        type = "copy",
        parts = MapSystem.Clipboard,
        time = os.time(),
    })
    MapSystem.HistoryIndex = #MapSystem.History
end

-- Create Part from Data
local function CreatePartFromData(data, position)
    local part = Instance.new(data.Class or "Part")
    
    -- Basic properties
    part.Name = data.Name .. "_copy"
    part.Size = data.Size
    part.CFrame = data.CFrame + (position - data.Position)
    part.BrickColor = data.BrickColor
    part.Material = data.Material
    part.Color = data.Color3
    part.Transparency = data.Transparency
    part.Reflectance = data.Reflectance
    part.Anchored = data.Anchored
    part.CanCollide = data.CanCollide
    part.CanTouch = data.CanTouch
    part.Locked = data.Locked
    part.Massless = data.Massless
    
    -- Surface properties
    if data.Shape then part.Shape = data.Shape end
    if data.TopSurface then part.TopSurface = data.TopSurface end
    if data.BottomSurface then part.BottomSurface = data.BottomSurface end
    if data.FrontSurface then part.FrontSurface = data.FrontSurface end
    if data.BackSurface then part.BackSurface = data.BackSurface end
    if data.LeftSurface then part.LeftSurface = data.LeftSurface end
    if data.RightSurface then part.RightSurface = data.RightSurface end
    
    -- Physics
    if data.Velocity then part.Velocity = data.Velocity end
    if data.RotVelocity then part.RotVelocity = data.RotVelocity end
    if data.CustomPhysicalProperties then
        part.CustomPhysicalProperties = data.CustomPhysicalProperties
    end
    part.CollisionGroup = data.CollisionGroup
    
    -- Decals and textures
    for _, decalData in ipairs(data.Decals or {}) do
        local decal = Instance.new(decalData.Class)
        decal.Name = decalData.Name
        decal.Texture = decalData.Texture
        decal.Color3 = decalData.Color3
        decal.Transparency = decalData.Transparency
        decal.Face = decalData.Face
        decal.Parent = part
    end
    
    return part
end

-- Paste Parts
local function PasteParts(position)
    if #MapSystem.Clipboard == 0 then
        Notify("Error", "Clipboard is empty!", 2, "error")
        return
    end
    
    if not position then
        position = Mouse.Hit.p + MapSystem.Settings.PasteOffset
    end
    
    -- Apply random offset if enabled
    if MapSystem.Settings.PasteRandomOffset then
        local range = MapSystem.Settings.RandomOffsetRange
        position = position + Vector3.new(
            math.random(-range * 10, range * 10) / 10,
            math.random(-range, range),
            math.random(-range * 10, range * 10) / 10
        )
    end
    
    -- Snap to grid if enabled
    if MapSystem.Settings.SnapToGrid then
        local grid = MapSystem.Settings.GridSize
        position = Vector3.new(
            math.round(position.X / grid) * grid,
            math.round(position.Y / grid) * grid,
            math.round(position.Z / grid) * grid
        )
    end
    
    local pastedGroup = Instance.new("Model")
    pastedGroup.Name = "Pasted_" .. os.date("%H%M%S")
    pastedGroup.Parent = Workspace
    
    local pastedParts = {}
    
    for _, data in ipairs(MapSystem.Clipboard) do
        local part = CreatePartFromData(data, position)
        part.Parent = pastedGroup
        table.insert(pastedParts, part)
        
        -- Highlight newly pasted parts briefly
        HighlightPart(part, Color3.fromRGB(0, 255, 0), 1)
    end
    
    MapSystem.Stats.TotalPasted = MapSystem.Stats.TotalPasted + #MapSystem.Clipboard
    Notify("Pasted", string.format("%d parts pasted", #MapSystem.Clipboard), 2, "success")
    
    return pastedGroup, pastedParts
end

-- Save Map
local function SaveMap(filename)
    if #MapSystem.Clipboard == 0 then
        Notify("Error", "No data to save!", 2, "error")
        return
    end
    
    local saveData = {
        version = "5.0",
        date = os.date("%Y-%m-%d %H:%M:%S"),
        author = Player.Name,
        executor = Executor.name,
        stats = {
            parts = #MapSystem.Clipboard,
            size = string.format("%d bytes", #HttpService:JSONEncode(MapSystem.Clipboard)),
        },
        parts = MapSystem.Clipboard,
        settings = MapSystem.Settings,
    }
    
    if not filename then
        filename = string.format("Map_%s.json", os.date("%Y%m%d_%H%M%S"))
    end
    
    if SaveToFile(filename, saveData) then
        MapSystem.Stats.TotalSaved = MapSystem.Stats.TotalSaved + 1
        Notify("Saved", string.format("Saved to %s", filename), 3, "success")
        return true
    else
        Notify("Error", "Failed to save file!", 3, "error")
        return false
    end
end

-- Load Map
local function LoadMap(filename)
    local data = LoadFromFile(filename)
    if not data then
        Notify("Error", "Failed to load file!", 3, "error")
        return
    end
    
    MapSystem.Clipboard = data.parts
    MapSystem.Settings = data.settings or MapSystem.Settings
    
    MapSystem.Stats.TotalLoaded = MapSystem.Stats.TotalLoaded + 1
    Notify("Loaded", string.format("Loaded %d parts from %s", #MapSystem.Clipboard, filename), 3, "success")
    
    return true
end

-- Undo last operation
local function Undo()
    if MapSystem.HistoryIndex <= 1 then
        Notify("Undo", "Nothing to undo", 2, "warning")
        return
    end
    
    MapSystem.HistoryIndex = MapSystem.HistoryIndex - 1
    local lastOp = MapSystem.History[MapSystem.HistoryIndex]
    
    if lastOp.type == "copy" then
        MapSystem.Clipboard = lastOp.parts
        Notify("Undo", "Restored previous clipboard", 2, "info")
    end
end

-- Redo last operation
local function Redo()
    if MapSystem.HistoryIndex >= #MapSystem.History then
        Notify("Redo", "Nothing to redo", 2, "warning")
        return
    end
    
    MapSystem.HistoryIndex = MapSystem.HistoryIndex + 1
    local nextOp = MapSystem.History[MapSystem.HistoryIndex]
    
    if nextOp.type == "copy" then
        MapSystem.Clipboard = nextOp.parts
        Notify("Redo", "Restored clipboard", 2, "info")
    end
end

-- Create Grid
local function CreateGrid(center, size, spacing)
    -- Clear existing grid
    for _, part in ipairs(MapSystem.UI.GridParts) do
        if part then part:Destroy() end
    end
    MapSystem.UI.GridParts = {}
    
    if not MapSystem.UI.ShowGrid then return end
    
    -- Create grid lines
    for x = -size, size, spacing do
        for z = -size, size, spacing do
            if math.abs(x) <= size and math.abs(z) <= size then
                local marker = Instance.new("Part")
                marker.Size = Vector3.new(0.5, 0.1, 0.5)
                marker.CFrame = CFrame.new(center.X + x, center.Y, center.Z + z)
                marker.Anchored = true
                marker.CanCollide = false
                marker.Transparency = 0.7
                marker.BrickColor = BrickColor.new("Bright blue")
                marker.Material = Enum.Material.Neon
                marker.Parent = Workspace
                table.insert(MapSystem.UI.GridParts, marker)
            end
        end
    end
end

