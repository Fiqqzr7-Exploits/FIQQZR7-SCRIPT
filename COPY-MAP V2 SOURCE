local function Notify(title, content, duration, type)
    WindUI:Notify({
        Title = title,
        Content = content,
        Duration = duration or 3,
        Type = type or "info"
    })
end

local function SaveToFile(filename, data)
    if not Executor.supports.files then
        Notify("Error", "File system not supported!", 3, "error")
        return false
    end
    
    local success = pcall(function()
        writefile(filename, HttpService:JSONEncode(data))
    end)
    
    return success
end

local function LoadFromFile(filename)
    if not Executor.supports.files then
        Notify("Error", "File system not supported!", 3, "error")
        return nil
    end
    
    local success, data = pcall(function()
        return HttpService:JSONDecode(readfile(filename))
    end)
    
    return success and data or nil
end

local function CopyToClipboard(text)
    if setclipboard then
        setclipboard(text)
        return true
    elseif toclipboard then
        toclipboard(text)
        return true
    end
    return false
end

