-------------------- RENDER FUNCTIONS --------------------
local activeTab = "emote"

local function updatePageLabel()
    if activeTab ~= "emote" then
        pageLabel.Text = ""
        return
    end
    
    if externalTotal == 0 then
        pageLabel.Text = "0 / 0  EMOTE"
        return
    end
    
    local lastIndex = math.min(externalPage * CONFIG.MaxVisible, externalTotal)
    pageLabel.Text = string.format("%d / %d  EMOTE", lastIndex, externalTotal)
end

function renderEmotePage()
    for _, child in ipairs(gridEmote:GetChildren()) do
        if child:IsA("Frame") then
            child:Destroy()
        end
    end
    
    if externalTotal == 0 then
        local loadingLabel = Instance.new("TextLabel")
        loadingLabel.Size = UDim2.new(1, 0, 0, round(22 * CONFIG.ScaleFactor))
        loadingLabel.Position = UDim2.new(0, 0, 0.5, -round(11 * CONFIG.ScaleFactor))
        loadingLabel.BackgroundTransparency = 1
        loadingLabel.Text = "LOADING EMOTES..."
        loadingLabel.Font = Enum.Font.GothamBold
        loadingLabel.TextSize = round(14 * CONFIG.ScaleFactor)
        loadingLabel.TextColor3 = CONFIG.LightRed
        loadingLabel.Parent = gridEmote
        updatePageLabel()
        return
    end
    
    local totalPages = math.max(1, math.ceil(externalTotal / CONFIG.MaxVisible))
    externalPage = math.clamp(externalPage, 1, totalPages)
    
    local startIdx = (externalPage - 1) * CONFIG.MaxVisible + 1
    local endIdx = math.min(externalPage * CONFIG.MaxVisible, externalTotal)
    
    for i = startIdx, endIdx do
        local item = emoteCatalog[i]
        if item then
            createEmoteCard(
                item.id,
                item.name or getAssetName(item.id),
                function(id) playEmote(id) end,
                function(id, btn)
                    local animIdStr = "rbxassetid://"..tostring(getRealAnimationId(id))
                    
                    for _, saved in ipairs(SavedEmotes) do
                        if saved.id == id then
                            btn.Text = "✓"
                            task.delay(0.5, function()
                                if btn then btn.Text = "☆ SAVE" end
                            end)
                            return
                        end
                    end
                    
                    table.insert(SavedEmotes, {
                        id = id,
                        name = item.name or getAssetName(item.id),
                        AnimationId = animIdStr
                    })
                    saveSaved()
                    
                    btn.Text = "✓ SAVED"
                    btn.BackgroundColor3 = CONFIG.DarkRed
                    
                    task.delay(0.4, function()
                        if btn then
                            btn.Text = "☆ SAVE"
                            btn.BackgroundColor3 = CONFIG.DarkRed
                        end
                    end)
                end,
                "save",
                gridEmote
            )
        end
    end
    
    updatePageLabel()
end

local savedPage = 1

function renderSavedPage()
    for _, child in ipairs(gridSaved:GetChildren()) do
        if child:IsA("Frame") then
            child:Destroy()
        end
    end
    
    if #SavedEmotes == 0 then
        local emptyLabel = Instance.new("TextLabel")
        emptyLabel.Size = UDim2.new(1, 0, 0, round(22 * CONFIG.ScaleFactor))
        emptyLabel.Position = UDim2.new(0, 0, 0.5, -round(11 * CONFIG.ScaleFactor))
        emptyLabel.BackgroundTransparency = 1
        emptyLabel.Text = "NO SAVED EMOTES"
        emptyLabel.Font = Enum.Font.GothamBold
        emptyLabel.TextSize = round(14 * CONFIG.ScaleFactor)
        emptyLabel.TextColor3 = CONFIG.LightRed
        emptyLabel.Parent = gridSaved
        return
    end
    
    savedPage = math.clamp(savedPage, 1, math.max(1, math.ceil(#SavedEmotes / CONFIG.MaxVisible)))
    
    local startIdx = (savedPage - 1) * CONFIG.MaxVisible + 1
    local endIdx = math.min(savedPage * CONFIG.MaxVisible, #SavedEmotes)
    
    for i = startIdx, endIdx do
        local item = SavedEmotes[i]
        if item then
            createEmoteCard(
                item.id,
                item.name or getAssetName(item.id),
                function()
                    if item.AnimationId then
                        stopCurrentEmote()
                        local anim = Instance.new("Animation")
                        anim.AnimationId = item.AnimationId
                        local success, track = pcall(function() 
                            return animator:LoadAnimation(anim) 
                        end)
                        if success and track then
                            track.Priority = Enum.AnimationPriority.Action
                            track.Looped = true
                            track:Play(0.1, 1, 1)
                            track:AdjustSpeed(1)
                            CurrentTrack = track
                        end
                    else
                        playEmote(item.id)
                    end
                end,
                function(_, btn)
                    table.remove(SavedEmotes, i)
                    saveSaved()
                    if (savedPage - 1) * CONFIG.MaxVisible >= #SavedEmotes and savedPage > 1 then
                        savedPage = savedPage - 1
                    end
                    renderSavedPage()
                end,
                "remove",
                gridSaved
            )
        end
    end
end

-------------------- TAB SWITCHING --------------------
local function switchTab(tab)
    activeTab = tab
    paneEmote.Visible = (tab == "emote")
    paneSaved.Visible = (tab == "saved")
    
    local emoteColor = (tab == "emote") and CONFIG.DarkRed or CONFIG.DarkGray
    local savedColor = (tab == "saved") and CONFIG.DarkRed or CONFIG.DarkGray
    
    TweenService:Create(tabEmote, TweenInfo.new(0.2), {BackgroundColor3 = emoteColor}):Play()
    TweenService:Create(tabSaved, TweenInfo.new(0.2), {BackgroundColor3 = savedColor}):Play()
    
    stopCurrentEmote()
    
    if tab == "emote" then
        renderEmotePage()
    else
        renderSavedPage()
    end
    
    updatePageLabel()
end

tabEmote.MouseButton1Click:Connect(function() switchTab("emote") end)
tabSaved.MouseButton1Click:Connect(function() switchTab("saved") end)

