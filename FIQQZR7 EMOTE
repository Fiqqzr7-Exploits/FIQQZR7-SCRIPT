nextBtn.MouseButton1Click:Connect(function()
    if activeTab == "saved" then
        if #SavedEmotes == 0 then return end
        local maxPage = math.max(1, math.ceil(#SavedEmotes / CONFIG.MaxVisible))
        savedPage = (savedPage < maxPage) and (savedPage + 1) or 1
        renderSavedPage()
        return
    end
    
    if externalTotal > 0 then
        local maxPage = math.max(1, math.ceil(externalTotal / CONFIG.MaxVisible))
        externalPage = (externalPage < maxPage) and (externalPage + 1) or 1
        renderEmotePage()
    end
end)

prevBtn.MouseButton1Click:Connect(function()
    if activeTab == "saved" then
        if #SavedEmotes == 0 then return end
        local maxPage = math.max(1, math.ceil(#SavedEmotes / CONFIG.MaxVisible))
        savedPage = (savedPage > 1) and (savedPage - 1) or maxPage
        renderSavedPage()
        return
    end
    
    if externalTotal > 0 then
        local maxPage = math.max(1, math.ceil(externalTotal / CONFIG.MaxVisible))
        externalPage = (externalPage > 1) and (externalPage - 1) or maxPage
        renderEmotePage()
    end
end)

