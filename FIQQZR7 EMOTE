    TweenService:Create(innerImage, TweenInfo.new(0.15), {Size = UDim2.new(1, -4, 1, -4)}):Play()
end)

-- Save position
local function saveTogglePosition()
    if not IO_AVAILABLE then return end
    
    local pos = toggleBtn.AbsolutePosition
    local data = {x = pos.X, y = pos.Y}
    pcall(function()
        writefile(POS_FILE, HttpService:JSONEncode(data))
    end)
end

-- Load saved position
pcall(function()
    if IO_AVAILABLE and isfile(POS_FILE) then
        local data = HttpService:JSONDecode(readfile(POS_FILE))
        if type(data) == "table" and data.x and data.y then
            toggleBtn.Position = UDim2.fromOffset(data.x, data.y)
        end
    end
end)

UserInputService.InputEnded:Connect(function(input)
    if toggleDragging and (input.UserInputType == Enum.UserInputType.MouseButton1 or 
                          input.UserInputType == Enum.UserInputType.Touch) then
        toggleDragging = false
        saveTogglePosition()
    end
end)

