-------------------- UTILS -------------------------
local function round(n)
    return math.floor(n + 0.5)
end

local function createCorner(obj, radius)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, radius or 10)
    corner.Parent = obj
    return corner
end

local function createGlossy(frame, radius)
    createCorner(frame, radius)
    
    local gloss = Instance.new("Frame")
    gloss.Name = "Gloss"
    gloss.Parent = frame
    gloss.BackgroundTransparency = 0.9
    gloss.BackgroundColor3 = Color3.new(1,1,1)
    gloss.BorderSizePixel = 0
    gloss.ZIndex = (frame.ZIndex or 1) + 1
    gloss.Size = UDim2.new(1,0,0, math.max(6, math.floor((frame.AbsoluteSize.Y/300)*18)))

    local gradient = Instance.new("UIGradient")
    gradient.Parent = gloss
    gradient.Rotation = 90
    gradient.Color = ColorSequence.new(Color3.new(1,1,1), Color3.new(0,0,0))
    gradient.Transparency = NumberSequence.new{
        NumberSequenceKeypoint.new(0, 0.9),
        NumberSequenceKeypoint.new(1, 1)
    }
    
    return gloss
end

-------------------- ANIMATION CACHE --------------------
local AnimCache = {}
local function getRealAnimationId(id)
    if not id then return nil end
    if AnimCache[id] then return AnimCache[id] end
    
    local success, objects = pcall(function() 
        return game:GetObjects("rbxassetid://"..tostring(id)) 
    end)
    
    if success and objects and #objects > 0 then
        local found
        for _, root in ipairs(objects) do
            if root:IsA("Animation") and root.AnimationId ~= "" then
                found = tonumber(root.AnimationId:match("%d+")) or found
            else
                for _, descendant in ipairs(root:GetDescendants()) do
                    if descendant:IsA("Animation") and descendant.AnimationId ~= "" then
                        found = tonumber(descendant.AnimationId:match("%d+")) or found
                        if found then break end
                    end
                end
            end
            pcall(function() root:Destroy() end)
            if found then break end
        end
        AnimCache[id] = found or id
        return AnimCache[id]
    end
    
    AnimCache[id] = id
    return id
end

-------------------- NAME CACHE --------------------
local NameCache = {}
local function getAssetName(assetId)
    if NameCache[assetId] then return NameCache[assetId] end
    
    local success, info = pcall(MarketplaceService.GetProductInfo, MarketplaceService, tonumber(assetId))
    local name = (success and info and info.Name) and info.Name or ("Emote "..tostring(assetId))
    NameCache[assetId] = name
    return name
end

