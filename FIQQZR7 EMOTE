local function playClickSound()
    pcall(function()
        local sound = Instance.new("Sound")
        sound.SoundId = CONFIG.ClickSoundId
        sound.Volume = 1
        sound.PlayOnRemove = false
        
        local playerGui = player:FindFirstChild("PlayerGui") or player:WaitForChild("PlayerGui")
        sound.Parent = playerGui
        sound:Play()
        
        sound.Ended:Connect(function()
            pcall(function() sound:Destroy() end)
        end)
        
        task.delay(6, function()
            if sound and sound.Parent then
                pcall(function() sound:Destroy() end)
            end
        end)
    end)
end

-------------------- EXTERNAL EMOTE LOADER --------------------
local emoteCatalog = {}
local externalTotal = 0
local externalPage = 1

local function loadExternalEmotes()
    task.spawn(function()
        local success, body = pcall(function() 
            return game:HttpGet(CONFIG.ExternalUrl) 
        end)
        
        if not success or not body or body == "" then
            warn("Failed to load external emotes")
            return
        end
        
        local decoded, data = pcall(function() 
            return HttpService:JSONDecode(body) 
        end)
        
        if not decoded or not data or type(data.data) ~= "table" then
            warn("Failed to parse external emotes")
            return
        end
        
        emoteCatalog = {}
        for _, item in ipairs(data.data) do
            local id = tonumber(item.id)
            if id and id > 0 then
                table.insert(emoteCatalog, {
                    id = id,
                    name = item.name or ("Emote "..tostring(id))
                })
            end
        end
        
        externalTotal = #emoteCatalog
        externalPage = 1
        
        pcall(function() renderEmotePage() end)
    end)
end

