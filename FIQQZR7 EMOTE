-------------------- PLAYBACK SYSTEM --------------------
local CurrentTrack = nil
local StopOnMove = true

local function stopCurrentEmote()
    if CurrentTrack then
        pcall(function()
            CurrentTrack:Stop(0.1)
            CurrentTrack:Destroy()
        end)
        CurrentTrack = nil
    end
end

local function playEmote(assetId)
    stopCurrentEmote()
    
    local realId = getRealAnimationId(assetId)
    if not realId then return end
    
    local anim = Instance.new("Animation")
    anim.AnimationId = "rbxassetid://"..tostring(realId)
    
    local success, track = pcall(function() 
        return animator:LoadAnimation(anim) 
    end)
    
    if success and track then
        track.Priority = Enum.AnimationPriority.Action
        track.Looped = true
        track:Play(0.1, 1, 1)
        track:AdjustSpeed(1)
        CurrentTrack = track
    end
end

-- Auto-stop when moving
local lastMoveCheck = 0
local MOVE_GRACE = 0.15
local MOVE_THRESHOLD = 0.05

RunService.RenderStepped:Connect(function(deltaTime)
    if not StopOnMove then return end
    if not (character and humanoid and CurrentTrack and CurrentTrack.IsPlaying) then return end
    
    lastMoveCheck = lastMoveCheck + deltaTime
    if lastMoveCheck < MOVE_GRACE then return end
    lastMoveCheck = 0
    
    local moveDir = humanoid.MoveDirection
    local isMoving = (moveDir and moveDir.Magnitude or 0) > MOVE_THRESHOLD
    local state = humanoid:GetState()
    local isJumping = (state == Enum.HumanoidStateType.Jumping) or (state == Enum.HumanoidStateType.Freefall)
    
    if isMoving or isJumping then
        stopCurrentEmote()
    end
end)

